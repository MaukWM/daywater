DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# Inspect AI / Anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Path to a Ghidra install (analyzeHeadless must live at $SPECTRE_GHIDRA_HOME/support/analyzeHeadless)
SPECTRE_GHIDRA_HOME=

# Per-sample ROM + savestate paths (gitignored, large licensed binaries)
SPECTRE_NIGHTFIRE_ISO=roms/nightfire.iso
SPECTRE_NIGHTFIRE_SAV=roms/GO7E69.s01

# Optional: pre-built ELF (from a decomp project) to analyze instead of the
# extracted main.dol. Recommended — covers RELs and the full address space.
SPECTRE_NIGHTFIRE_ELF=roms/nightfire.elf
